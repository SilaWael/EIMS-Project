# EIMS .gitignore
# ===============
# This file controls what gets uploaded to GitHub.
#
# IMPORTANT: The cloud sync script (sync_to_cloud.bat) uses `git add -f`
# (force) to upload eims.db to GitHub, ignoring this file. This is by design.
# If you want to PREVENT eims.db from being uploaded, run git commands
# manually instead of using sync_to_cloud.bat.

# Python cache
__pycache__/
*.py[cod]
*.pyc

# Windows system files
desktop.ini
Thumbs.db

# Local run script (Windows-only)
run_app.bat

# Secrets — NEVER commit
.env
.env.local
.env.production

# Logs
logs/*.log
logs/*.log.*

# Backups (database snapshots)
backups/*.db

# Old v1 backups (kept locally for reference)
app_v1_backup.py
eims.db.backup_v1

# Database — DEFAULT: ignored for security
# (The sync_to_cloud.bat script overrides this with -f flag)
eims.db

# Uploaded PDFs (filesystem mode) — these go to DB as BLOBs in cloud mode
# Local-only PDFs stay here, but are not pushed to GitHub
pdf_archive/*.pdf
pdf_archive/*.html
pdf_archive/*.htm
pdf_archive/*.jpg
pdf_archive/*.jpeg
pdf_archive/*.png
